<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <ImageView
        android:id="@+id/ivEmptyStateIcon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/baseline_edit_24"
        android:alpha="0.3"
        android:tint="@color/textSecondary" />

    <TextView
        android:id="@+id/tvEmptyStateTitle"
        style="@style/SnapFine.Text.Subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="@string/empty_default_title"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvEmptyStateSubtitle"
        style="@style/SnapFine.Text.Caption"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:gravity="center"
        android:text="@string/empty_default_subtitle"
        android:textColor="@color/textSecondary" />

</LinearLayout>
