<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="4dp"
    app:strokeWidth="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvUserName"
            style="@style/SnapFine.Text.Subtitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            tools:text="John Doe" />

        <TextView
            android:id="@+id/tvUserEmail"
            style="@style/SnapFine.Text.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:drawableStart="@drawable/baseline_person_24"
            android:drawablePadding="8dp"
            android:drawableTint="@color/textSecondary"
            tools:text="john.doe@example.com" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginVertical="12dp"
            android:background="#F0F0F0" />

        <TextView
            style="@style/SnapFine.Text.Caption"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="VEHICLE DETAILS"
            android:textStyle="bold"
            android:textColor="@color/statusPending" />

        <TextView
            android:id="@+id/tvVehicleDetails"
            style="@style/SnapFine.Text.Body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            tools:text="KA01HH1234 (SUV)" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReject"
                style="@style/SnapFine.Button.Secondary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:layout_weight="1"
                android:text="Reject"
                android:textColor="@color/statusError"
                app:strokeColor="@color/statusError" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnApprove"
                style="@style/SnapFine.Button.Primary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Approve"
                app:backgroundTint="@color/statusSuccess" />

        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
