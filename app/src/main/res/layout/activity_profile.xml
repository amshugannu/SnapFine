<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Profile Header -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingVertical="16dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Back"
                android:src="@drawable/baseline_arrow_back_24"
                app:tint="@color/textPrimary" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:orientation="vertical">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/ivProfileImage"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/baseline_person_24"
                    app:shapeAppearanceOverlay="@style/RoundedCorners"
                    app:strokeColor="@color/colorPrimary"
                    app:strokeWidth="2dp" />

                <TextView
                    android:id="@+id/tvHeaderName"
                    style="@style/SnapFine.Text.Title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    tools:text="John Doe" />

                <TextView
                    android:id="@+id/tvHeaderEmail"
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="john.doe@example.com" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Basic Info Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/SnapFine.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_full_name"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvFullName"
                    style="@style/SnapFine.Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    tools:text="John Doe" />

                <View style="@style/SnapFine" android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                <TextView
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_email"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvEmail"
                    style="@style/SnapFine.Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    tools:text="john.doe@example.com" />

                <View style="@style/SnapFine" android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                <TextView
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_phone"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvPhone"
                    style="@style/SnapFine.Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="+91 9876543210" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Vehicle Info Card -->
        <TextView
            style="@style/SnapFine.Text.Subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:layout_marginBottom="8dp"
            android:text="@string/label_vehicle_info"
            android:textStyle="bold" />

        <com.google.android.material.card.MaterialCardView
            style="@style/SnapFine.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/SnapFine.Text.Caption" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_vehicle_number" android:textStyle="bold" />
                        <TextView android:id="@+id/tvVehicleNumber" style="@style/SnapFine.Text.Body" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" tools:text="KA01AB1234" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView style="@style/SnapFine.Text.Caption" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="@string/label_vehicle_type" android:textStyle="bold" />
                        <TextView android:id="@+id/tvVehicleType" style="@style/SnapFine.Text.Body" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="4dp" tools:text="Car" />
                    </LinearLayout>
                </LinearLayout>

                <View style="@style/SnapFine" android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginVertical="12dp"/>

                <TextView
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_registration_id"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvRegistrationId"
                    style="@style/SnapFine.Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="12dp"
                    tools:text="REG-1234567890" />

                <View style="@style/SnapFine" android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0"/>

                <TextView
                    style="@style/SnapFine.Text.Caption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:text="@string/label_license_number"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvLicenseNumber"
                    style="@style/SnapFine.Text.Body"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    tools:text="DL-9876543210" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Action Buttons -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnEditProfile"
            style="@style/SnapFine.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="@string/btn_edit_profile" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            style="@style/SnapFine.Button.Secondary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="32dp"
            android:text="Logout" />

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
