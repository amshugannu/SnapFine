<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GlassInputLayout" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/glassFieldBackground</item>
        <item name="boxStrokeColor">@android:color/transparent</item>
        <item name="boxStrokeWidth">0dp</item>
        <item name="boxCornerRadiusTopStart">24dp</item>
        <item name="boxCornerRadiusTopEnd">24dp</item>
        <item name="boxCornerRadiusBottomStart">24dp</item>
        <item name="boxCornerRadiusBottomEnd">24dp</item>
    </style>
    <style name="GlassEditText" parent="Widget.MaterialComponents.TextInputEditText.OutlinedBox">
        <item name="android:background">@android:color/transparent</item>
        <item name="android:textColor">@color/primaryBlue</item>
        <item name="android:textColorHint">@color/hintGray</item>
        <item name="android:paddingLeft">16dp</item>
        <item name="android:paddingRight">16dp</item>
    </style>

    <!-- Button Styles -->
    <style name="Widget.SnapFine.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_primary</item>
        <item name="backgroundTint">@color/colorPrimary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">@dimen/button_radius</item>
        <item name="android:paddingVertical">12dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
    </style>

    <style name="SnapFine.Button.Primary" parent="Widget.SnapFine.Button.Primary" />

    <!-- SnapFine Design System Base -->
    <style name="SnapFine" />

    <!-- Card Styles -->
    <style name="SnapFine.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/colorCard</item>
        <item name="cardCornerRadius">@dimen/card_radius</item>
        <item name="cardElevation">@dimen/elevation_card</item>
        <item name="android:layout_margin">@dimen/margin_standard</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
        <item name="android:stateListAnimator">@animator/card_elevation_selector</item>
    </style>

    <!-- Typography Styles -->
    <style name="SnapFine.Text" />

    <style name="SnapFine.Text.Title">
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="SnapFine.Text.Subtitle">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>

    <style name="SnapFine.Text.Body">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/textPrimary</item>
    </style>

    <style name="SnapFine.Text.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>

    <style name="RoundedCorners">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>